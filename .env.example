# Express API (in separate folder)
# Direct: set full URL (Express must enable CORS)
# Proxy: set /api/backend and add BACKEND_URL below
NEXT_PUBLIC_API_URL=http://localhost:3001

# For Next.js rewrites (optional - avoids CORS in dev)
# Proxies /api/backend/* to your Express server
BACKEND_URL=http://localhost:3001
